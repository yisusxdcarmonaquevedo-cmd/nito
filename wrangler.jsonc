{
  // Configuración de despliegue en Cloudflare.
  // - La web estática vive en /web y se sirve tal cual.
  // - worker/index.js es el "despertador": su cron dispara el pipeline de GitHub
  //   cada 15 min (los crons de GitHub no arrancan en cuentas nuevas).
  "name": "nito",
  "compatibility_date": "2026-07-04",
  "main": "worker/index.js",
  "assets": {
    "directory": "web",
    "binding": "ASSETS"
  },
  "triggers": {
    "crons": ["*/15 * * * *"]
  }
}
